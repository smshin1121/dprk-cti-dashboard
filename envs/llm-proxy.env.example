# Environment template for the LLM Proxy service.
# Copy to envs/llm-proxy.env and fill in real values.  Never commit the real file.
#
# OPENAI_API_KEY lives ONLY here.  No other service needs it; the proxy
# abstracts the provider so the key never needs to leave this container.

OPENAI_API_KEY=sk-CHANGE_ME
LLM_PROXY_INTERNAL_TOKEN=CHANGE_ME_shared_secret
APP_ENV=dev
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=llm-proxy
# Set to "false" when the collector terminates TLS (e.g. behind a service mesh).
# Default "true" preserves the previous hardcoded behavior for plain-gRPC dev/CI.
OTEL_EXPORTER_OTLP_INSECURE=true
