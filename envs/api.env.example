# Environment template for the API service.
# Copy to envs/api.env and fill in real values.  Never commit the real file.
#
# OPENAI_API_KEY is intentionally absent here — it belongs only in
# envs/llm-proxy.env.example to enforce least-privilege secret scoping.

APP_ENV=dev
DATABASE_URL=postgresql+psycopg://postgres:CHANGE_ME@db:5432/dprk_cti
REDIS_URL=redis://:${REDIS_PASSWORD}@cache:6379/0
CORS_ORIGINS=http://localhost:5173
LLM_PROXY_URL=http://llm-proxy:8010
LLM_PROXY_INTERNAL_TOKEN=CHANGE_ME_shared_secret
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=api
# OTLP/gRPC transport security. Default "true" matches dev/CI plain-gRPC
# collector. PROD: set to "false" when the collector terminates TLS (e.g.
# behind a service mesh). Recognized: true/1/yes/false/0/no (case-insensitive);
# any other value falls through to true with a logger.warning.
OTEL_EXPORTER_OTLP_INSECURE=true

# Keycloak OIDC
OIDC_ISSUER_URL=http://keycloak:8080/realms/dprk-cti
OIDC_CLIENT_ID=dprk-cti-api
OIDC_CLIENT_SECRET=dev-secret-rotate-in-prod
OIDC_REDIRECT_BASE_URL=http://localhost:8000

# Session
SESSION_SIGNING_KEY=CHANGE_ME_32plus_random_bytes
# SESSION_COOKIE_NAME defaults to "__Host-dprk_cti_session" (browser
# enforces Secure + Path=/ + no Domain). Dev compose serves HTTP, so
# the browser would reject __Host- prefixed cookies; this template
# explicitly overrides to the bare name for local development. PROD
# deployments leave this unset (default takes effect) — the
# `_enforce_session_cookie_host_prefix_in_prod` validator on Settings
# fail-closes any prod override that drops the prefix.
SESSION_COOKIE_NAME=dprk_cti_session
# SESSION_COOKIE_SECURE defaults to "true" (secure-by-default at the API
# config layer). Dev compose serves HTTP, so this template explicitly
# overrides to "false" for local development. PROD deployments behind
# TLS-terminating reverse proxies should leave this unset (default true)
# or set it to "true" explicitly.
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_TTL_SECONDS=3600
