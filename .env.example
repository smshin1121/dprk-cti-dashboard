# Compose infrastructure secrets only. Application secrets live in envs/*.env.example.
#
# SCOPE SPLIT: per-service secrets live in envs/<service>.env.example.
#   envs/api.env.example        — DATABASE_URL, OIDC_*, CORS_ORIGINS, etc.
#   envs/worker.env.example     — DATABASE_URL, PREFECT_API_URL, LLM_PROXY_INTERNAL_TOKEN, etc.
#   envs/llm-proxy.env.example  — OPENAI_API_KEY (ONLY here), LLM_PROXY_INTERNAL_TOKEN, etc.

APP_ENV=dev
LOG_LEVEL=INFO
TZ=Asia/Seoul
DOMAIN=localhost

COMPOSE_PROJECT_NAME=dprk-cti

POSTGRES_DB=dprk_cti
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_PORT=5432

REDIS_PASSWORD=change-me

API_PORT=8000
LLM_PROXY_PORT=8010
FRONTEND_PORT=5173

# Frontend runtime config — injected at container startup into window.__APP_CONFIG__
# (see apps/frontend/docker-entrypoint.sh and apps/frontend/src/config.ts).
FRONTEND_API_URL=/api/v1
FRONTEND_LLM_PROXY_URL=
# APP_ENV is reused from the top of this file for the frontend bundle.

PROMETHEUS_PORT=9090
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# Keycloak (dev OIDC provider)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me
KEYCLOAK_PORT=8081

# Realm-template substitution targets (PR #50 — moves dev credentials out of
# the committed realm-export.json into env-driven init-container render).
# These defaults preserve the historical dev experience (`test1234` /
# `dev-secret-rotate-in-prod`) but are now CONTRIBUTOR-OVERRIDABLE without
# touching version-controlled JSON. Production MUST set real values per
# `infra/keycloak/README.md` § "Production note".
DPRK_DEV_USER_PASSWORD=test1234
DPRK_DEV_CLIENT_SECRET=dev-secret-rotate-in-prod
